# NeonGrid Server Environment Variables

# The port the server should listen on. Most hosting providers (Render, Railway, Heroku) set this automatically.
PORT=3001

# The URL of your hosted client (for CORS validation). 
# Change this to your deployed frontend URL in production (e.g., https://neongrid.vercel.app)
# You can leave it blank or * to allow all origins.
CLIENT_URL=https://grid-game-dun.vercel.app
